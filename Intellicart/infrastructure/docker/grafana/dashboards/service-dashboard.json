{
  "title": "Service Dashboard",
  "tags": ["service", "jvm", "http"],
  "timezone": "browser",
  "panels": [
    {
      "title": "JVM Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) by (application)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Requests Rate (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count[5m])",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
